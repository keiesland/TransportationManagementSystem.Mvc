@using TransportationManagementSystem.Data.DTOs
@using TransportationManagementSystem.Data.Grid
@using TransportationManagementSystem.ViewModels
@using NPOI.SS.Formula.Functions
@model TransportationManagementSystem.ViewModels.SummaryListViewModel

@{
    ViewData["Title"] = " | Summary List";

    // aliases to make paging, sorting, and filtering code shorter
    RideDictionary current = Model.CurrentRoute;
    RideDictionary routes = Model.CurrentRoute.Clone();
}

<h1 class="text-center py-3" style="color: white; margin: 0; border-bottom: 2px solid black; text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
    background: linear-gradient(180deg, #1e3a5f, #007bff);">
    Summary List
</h1>

@using (Html.BeginForm("ExportAndClear", "Summary", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <input type="submit" class="btn btn-export m-2" value="Export To Excel" />
}

@* filter form *@
<form asp-action="Filter" method="post" class="form-inline">

    <label style="font-weight:bold" m-2>Driver:</label>
    <select name="filter" class="form-control"
            asp-items="@(new SelectList(
                                       Model.Drivers, "DriverId", "FullName", current.DriverFilter))">
        <option value="@SummaryGridDTO.DefaultFilter">All</option>
    </select>

    <label style="font-weight:bold" m-2>Date:</label>
    <select name="filter" class="form-control"
            asp-items="@(new SelectList(
                                       Model.TripDates, "TripDateId", "Date", current.TripDateFilter))">
        <option value="@SummaryGridDTO.DefaultFilter">All</option>
    </select>

    <button type="submit" class="btn bg-custom m-2">Filter</button>
    <button type="submit" class="btn bg-custom" name="clear" value="true">Clear</button>

</form>

<table class="table table-striped table-bordered">
    @* for each table column, update the route dictionary with the field to sort by, and then use
        that route dictionary and the current route to create route segments for sorting link *@
    <thead class="thead-dark">
        <tr>
            <th>
                @{
                    routes.SetSortAndDirection(nameof(Summary.Driver.FullName), current);
                }
                <a asp-action="List" asp-all-route-data="@routes"
                   style="color:aqua"></a>
            </th>
            <th>Driver</th>
            <th>Date</th>
            <th>Start</th>
            <th>Out 1</th>
            <th>In 1</th>
            <th>Out 2</th>
            <th>In 2</th>
            <th>Out 3</th>
            <th>In 3</th>
            <th>Out 4</th>
            <th>In 4</th>
            <th>End</th>
            <th>Actual Time</th>
            <th>Weekly Time</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Summary summary in Model.Summaries)
        {
            <tr>
                <td>
                    <a type="hidden" asp-action="Details" asp-route-id="@summary.SummaryId"></a>
                </td>
                <td>@summary.Driver.FullName</td>
                <td>@summary.TripDate.Date.ToShortDateString()</td>
                <td>@summary.Start</td>
                <td>
                    @if (summary.Out1 != TimeSpan.Zero)
                    {
                        @summary.Out1
                    }
                </td>
                <td>
                    @if (summary.In1 != TimeSpan.Zero)
                    {
                        @summary.In1
                    }
                </td>
                <td>
                    @if (summary.Out2 != TimeSpan.Zero)
                    {
                        @summary.Out2
                    }
                </td>
                <td>
                    @if (summary.In2 != TimeSpan.Zero)
                    {
                        @summary.In2
                    }
                </td>
                <td>
                    @if (summary.Out3 != TimeSpan.Zero)
                    {
                        @summary.Out3
                    }
                </td>
                <td>
                    @if (summary.In3 != TimeSpan.Zero)
                    {
                        @summary.In3
                    }
                </td>
                <td>
                    @if (summary.Out4 != TimeSpan.Zero)
                    {
                        @summary.Out4
                    }
                </td>
                <td>
                    @if (summary.In4 != TimeSpan.Zero)
                    {
                        @summary.In4
                    }
                </td>
                <td>@summary.End</td>
                <td>@summary.ActualTime</td>
                <td>@summary.WeeklyTime</td>
            </tr>
        }
    </tbody>
</table>


<partial name="_Pagination" model="@(new PaginationViewModel {
                                       CurrentRoute = Model.CurrentRoute,
                                       TotalPages = Model.TotalPages
                                   })" />